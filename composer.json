{
    "name": "pattonwebz/wp-stale-cache",
    "description": "Stale-while-revalidate caching for WordPress using Options API and WP-Cron",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "wordpress",
        "cache",
        "stale-while-revalidate",
        "performance"
    ],
    "authors": [
        {
            "name": "William Patton",
            "email": "will@pattonwebz.com"
        }
    ],
    "require": {
        "php": "^7.4",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "wp-phpunit/wp-phpunit": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Pattonwebz\\WpStaleCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pattonwebz\\WpStaleCache\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
