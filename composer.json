{
    "name": "pattonwebz/wp-stale-cache",
    "description": "Stale-while-revalidate caching for WordPress using Options API and WP-Cron",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "wordpress",
        "cache",
        "stale-while-revalidate",
        "performance"
    ],
    "authors": [
        {
            "name": "William Patton",
            "email": "will@pattonwebz.com"
        }
    ],
    "require": {
        "php": "^7.4",
        "ext-json": "*",
        "psr/log": "^1.1"
    },
    "suggest": {
        "pattonwebz/psr3-logger": "Optional PSR-3 logger for background refresh and cache state logging."
    },
    "require-dev": {
        "automattic/vipwpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "phpcompatibility/phpcompatibility-wp": "*",
        "phpunit/phpunit": "^9.6",
        "sirbrillig/phpcs-variable-analysis": "^2.11",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "wp-phpunit/wp-phpunit": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Pattonwebz\\WpStaleCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pattonwebz\\WpStaleCache\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    }
}
